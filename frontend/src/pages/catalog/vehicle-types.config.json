{
  "viewPermission":   "catalog.vehicle-types.view",
  "createPermission": "catalog.vehicle-types.create",
  "deletePermission": "catalog.vehicle-types.edit",
  "apiList":   "/api/admin/catalog/vehicle-types",
  "apiCreate": "/api/admin/catalog/vehicle-types",
  "apiUpdate": "/api/admin/catalog/vehicle-types",
  "apiDelete": "/api/admin/catalog/vehicle-types",

  "fields": {
    "id":         { "label": "ID",         "type": "integer",  "editable": false },
    "slug":       { "label": "Slug",       "type": "text",     "editable": true, "required": true, "createPermissions": ["catalog.vehicle-types.create"], "editPermissions": ["catalog.vehicle-types.edit"] },
    "name_uk":    { "label": "Назва [UA]", "type": "text",     "editable": true, "required": true, "createPermissions": ["catalog.vehicle-types.create"], "editPermissions": ["catalog.vehicle-types.edit"] },
    "name_en":    { "label": "Назва [EN]", "type": "text",     "editable": true, "required": true, "createPermissions": ["catalog.vehicle-types.create"], "editPermissions": ["catalog.vehicle-types.edit"] },
    "name_ru":    { "label": "Назва [RU]", "type": "text",     "editable": true, "default": "",    "createPermissions": ["catalog.vehicle-types.create"], "editPermissions": ["catalog.vehicle-types.edit"] },
    "created_at": { "label": "Створено",   "type": "datetime", "editable": false },
    "updated_at": { "label": "Оновлено",   "type": "datetime", "editable": false }
  },

  "table": [
    { "key": "id",      "width": 50, "align": "end", "sortable": false },
    { "key": "slug",                                  "sortable": true, "inlineEditable": true },
    { "key": "name_uk",                               "sortable": true, "inlineEditable": true },
    { "key": "name_en",                               "sortable": true, "inlineEditable": true },
    { "key": "name_ru",                               "sortable": true, "inlineEditable": true }
  ],

  "modal": [
    { "key": "id",         "col": 2  },
    { "key": "slug",       "col": 10 },
    { "key": "name_uk",    "col": 12 },
    { "key": "name_en",    "col": 12 },
    { "key": "name_ru",    "col": 12 },
    { "key": "created_at", "col": 6  },
    { "key": "updated_at", "col": 6  }
  ]
}
